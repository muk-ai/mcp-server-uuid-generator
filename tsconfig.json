{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["node"],
    "outDir": "./dist",
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.tsx"]
}
